FROM node:20-alpine AS build

WORKDIR /app/react-motor-control

COPY react-motor-control/package*.json ./
RUN npm ci

COPY react-motor-control ./

ARG VITE_API_URL=
ENV VITE_API_URL=${VITE_API_URL}
RUN npm run build

FROM nginx:1.27-alpine

COPY react-motor-control/deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/react-motor-control/dist /usr/share/nginx/html

EXPOSE 80
